---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Thank you for joining Trust Telegraph — Trust Leader" description="Your Trust Telegraph sign-up has been received." noindex>
  <section class="section response-page">
    <div class="shell response-card">
      <p class="eyebrow">Trust Telegraph</p>
      <h1>Thank you. You are on the list.</h1>
      <p>Look out for the confirmation or first note in your inbox. You can continue with the Trust Leader thinking while you wait.</p>
      <div class="hero__actions"><a class="button button--green" href="/the-thinking/">Read the thinking</a><a class="button button--outline" href="/knowledge-base/">Browse the Knowledge Base</a></div>
    </div>
  </section>
</BaseLayout>

