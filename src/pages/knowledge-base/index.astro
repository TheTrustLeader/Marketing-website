---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TelegraphCTA from '@/components/TelegraphCTA.astro';
import { getCollection } from 'astro:content';

const title = 'Knowledge Base — Trust Leader';
const description =
  'Clear explanations, activity guidance and useful language for trust work in real relationships.';

const topics = [
  { id: 'understand', number: '01', heading: 'Understand trust', text: 'Definitions, common misconceptions and the five Trust Questions.', link: '/the-thinking/' },
  { id: 'trust-map', number: '02', heading: 'Map a relationship', text: 'Choose a person, answer the questions and interpret the result carefully.', link: '/how-it-works/#trust-journey' },
  { id: 'behaviours', number: '03', heading: 'Choose a behaviour', text: 'Move from a broad concern to one behaviour that can make a useful difference.', link: '/knowledge-base/flag-it-early/' },
  { id: 'practise', number: '04', heading: 'Practise in real work', text: 'Use short activities to try something different in the relationship.', link: '/how-it-works/#trust-journey' },
  { id: 'reflect-review', number: '05', heading: 'Reflect and review', text: 'Record privately, notice evidence and decide what to do next.', link: '/how-it-works/#trust-journey' },
  { id: 'platform', number: '06', heading: 'Use the platform', text: 'Task-based walkthroughs will be added after the current Hub screens are captured.', link: '#walkthroughs' }
];
const knowledgeEntries = (await getCollection('knowledge')).sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
const allDrafts = knowledgeEntries.every((entry) => entry.data.status !== 'published');
---

<BaseLayout title={title} description={description} pageClass="knowledge-page" noindex={allDrafts}>
  <section class="kb-hero">
    <div class="shell kb-hero__grid">
      <div>
        <p class="eyebrow">Trust Leader Knowledge Base</p>
        <h1>Practical answers for trust work.</h1>
        <p class="lede">Find clear explanations, activity guidance and useful language for the relationship in front of you.</p>
        <form class="search-box" role="search" action="/knowledge-base/" method="get" data-knowledge-search>
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m16.2 16.2 4 4"></path></svg>
          <label class="visually-hidden" for="knowledge-search">Search the Knowledge Base</label>
          <input id="knowledge-search" name="q" type="search" placeholder="Search a question, behaviour or activity" />
          <button class="button button--small" type="submit">Filter</button>
        </form>
      </div>
      <aside class="kb-note" aria-label="Getting started">
        <strong>Not sure where to start?</strong>
        <p>The Trust Map helps you find a practical focus. The Knowledge Base helps you understand and act on it.</p>
      </aside>
    </div>
  </section>

  <section class="section section--paper" id="knowledge-pages" aria-labelledby="knowledge-pages-heading">
    <div class="shell">
      <div class="section-heading">
        <div><p class="eyebrow">Evergreen answers</p><h2 id="knowledge-pages-heading">Core trust questions, answered clearly.</h2></div>
        <p>Each page leads with a direct answer, separates the Trust Leader model from research and links to the next useful question.</p>
      </div>
      <p class="search-results-status" data-search-status aria-live="polite"></p>
      <div class="content-card-grid" data-content-list>
        {knowledgeEntries.map((entry) => (
          <article class:list={['content-card', `content-card--${entry.data.accent}`]} data-search-item={`${entry.data.title} ${entry.data.description} ${entry.data.eyebrow} ${entry.data.searchIntent}`.toLowerCase()}>
            <div class="content-card__top"><span>{entry.data.eyebrow}</span>{entry.data.status !== 'published' && <b>Draft for review</b>}</div>
            <h3><a href={`/knowledge-base/${entry.id}/`}>{entry.data.title}</a></h3>
            <p>{entry.data.description}</p>
            <div class="content-card__meta"><span>{entry.data.readTime}</span><a class="text-link" href={`/knowledge-base/${entry.id}/`}>Read the answer</a></div>
          </article>
        ))}
        <article class="content-card content-card--yellow" data-search-item="flagging risk early delivery consistency behaviour activity early warning">
          <div class="content-card__top"><span>Delivery &amp; Consistency</span><b>Example guide</b></div>
          <h3><a href="/knowledge-base/flag-it-early/">Why flagging a risk early strengthens delivery trust</a></h3>
          <p>Use a difficult early update to give the other person choices and reduce avoidable surprises.</p>
          <div class="content-card__meta"><span>7 minute read</span><a class="text-link" href="/knowledge-base/flag-it-early/">Read the guide</a></div>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="browse-heading">
    <div class="shell">
      <div class="section-heading">
        <div><p class="eyebrow">Browse by need</p><h2 id="browse-heading">Start with the question you have.</h2></div>
        <p>Arrive through a real question, find a plain answer and see where Trust Leader can support the work.</p>
      </div>
      <div class="topic-grid">
        {topics.map((topic) => (
          <article class="topic" id={topic.id}>
            <span class="topic__number">{topic.number}</span>
            <h3>{topic.heading}</h3>
            <p>{topic.text}</p>
            <a class="text-link" href={topic.link}>Explore this topic</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="walkthroughs" aria-labelledby="walkthrough-heading">
    <div class="shell">
      <div class="section-heading">
        <div><p class="eyebrow">Guided walkthroughs</p><h2 id="walkthrough-heading">See the task. Then do it.</h2></div>
        <p>Short click-through product guidance belongs here, where a visitor has a task to complete.</p>
      </div>
      <div class="guide-grid">
        <article class="guide-card">
          <div class="guide-card__visual" aria-hidden="true"><span>▶</span></div>
          <div><p class="meta">2-minute walkthrough</p><h3>Create your first Trust Map</h3><p>From choosing the relationship to identifying a focus.</p><span class="pending-link">Interactive guide pending product capture</span></div>
        </article>
        <article class="guide-card">
          <div class="guide-card__visual" aria-hidden="true"><span>↗</span></div>
          <div><p class="meta">90-second walkthrough</p><h3>Add an activity to a playlist</h3><p>Choose an activity that fits the behaviour and the real situation.</p><span class="pending-link">Interactive guide pending product capture</span></div>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--paper" id="popular" aria-labelledby="popular-heading">
    <div class="shell">
      <div class="section-heading">
        <div><p class="eyebrow">Frequently useful</p><h2 id="popular-heading">Answers people return to.</h2></div>
      </div>
      <div class="popular-list">
        <a href="/knowledge-base/flag-it-early/"><span>01</span><strong>Why flagging a risk early strengthens delivery trust</strong><em>Use a difficult update to create confidence rather than erode it.</em><b aria-hidden="true">→</b></a>
        <a href="/how-it-works/#trust-journey"><span>02</span><strong>Is a Trust Map a diagnostic?</strong><em>No. It is one person’s structured view of a relationship.</em><b aria-hidden="true">→</b></a>
        <a href="/how-it-works/#trust-journey"><span>03</span><strong>Are reflections shared automatically?</strong><em>No. Reflections and journals are private by default.</em><b aria-hidden="true">→</b></a>
        <a href="/how-it-works/#trust-journey"><span>04</span><strong>How do I choose one focus?</strong><em>Look for the behaviour that could make a useful difference in this relationship.</em><b aria-hidden="true">→</b></a>
      </div>
    </div>
  </section>

  <section class="section section--green">
    <div class="shell">
      <TelegraphCTA heading="Useful thinking beyond the how-to." text="Join practitioners exploring how confidence strengthens and erodes in real working relationships." />
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-knowledge-search]');
  const input = form?.querySelector<HTMLInputElement>('input[type="search"]');
  const items = [...document.querySelectorAll<HTMLElement>('[data-search-item]')];
  const status = document.querySelector<HTMLElement>('[data-search-status]');

  const filter = (query: string) => {
    const normalised = query.trim().toLowerCase();
    let visible = 0;
    items.forEach((item) => {
      const matches = !normalised || (item.dataset.searchItem || '').includes(normalised);
      item.hidden = !matches;
      if (matches) visible += 1;
    });
    if (status) status.textContent = normalised ? `${visible} result${visible === 1 ? '' : 's'} for “${query.trim()}”` : '';
  };

  const initial = new URLSearchParams(window.location.search).get('q') || '';
  if (input) input.value = initial;
  filter(initial);

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const query = input?.value || '';
    filter(query);
    const url = new URL(window.location.href);
    query ? url.searchParams.set('q', query) : url.searchParams.delete('q');
    window.history.replaceState({}, '', url);
  });
</script>
