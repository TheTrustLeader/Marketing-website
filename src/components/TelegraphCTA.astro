---
import { getSiteConfig } from '@/config/site';
import { defaultLocale, type EnabledLocale } from '@/i18n/config';
import { getMessages } from '@/i18n/messages';

interface Props {
  heading?: string;
  text?: string;
  locale?: EnabledLocale;
}

const { locale = defaultLocale } = Astro.props;
const siteConfig = getSiteConfig(locale);
const messages = getMessages(locale);
const {
  heading = messages.telegraph.heading,
  text = messages.telegraph.text
} = Astro.props;
---

<section class="telegraph" id="trust-telegraph" aria-labelledby="telegraph-heading">
  <div>
    <p class="eyebrow eyebrow--light">{messages.telegraph.eyebrow}</p>
    <h2 id="telegraph-heading">{heading}</h2>
    <p>{text}</p>
  </div>
  <a class="button button--yellow" href={siteConfig.telegraphUrl} data-analytics="join_trust_telegraph">{messages.telegraph.action}</a>
</section>
