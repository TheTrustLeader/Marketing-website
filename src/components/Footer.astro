---
import Brand from './Brand.astro';
import { getSiteConfig } from '@/config/site';
import { defaultLocale, localisePath, type EnabledLocale } from '@/i18n/config';
import { getMessages } from '@/i18n/messages';

interface Props {
  locale?: EnabledLocale;
}

const { locale = defaultLocale } = Astro.props;
const siteConfig = getSiteConfig(locale);
const messages = getMessages(locale);
---

<footer class="site-footer">
  <div class="shell">
    <div class="site-footer__grid">
      <div>
        <Brand inverse locale={locale} />
        <p class="site-footer__summary">{messages.footer.summary}</p>
      </div>
      <div>
        <h2>{messages.footer.explore}</h2>
        <a href={localisePath('/#how-it-works', locale)}>{messages.navigation.howItWorks}</a>
        <a href={localisePath('/#practitioners', locale)}>{messages.navigation.practitioners}</a>
        <a href={localisePath('/knowledge-base/', locale)}>{messages.navigation.knowledgeBase}</a>
      </div>
      <div>
        <h2>{messages.footer.connect}</h2>
        <a href={siteConfig.telegraphUrl}>{messages.telegraph.eyebrow}</a>
        <span class="site-footer__pending">{messages.footer.aboutPending}</span>
        <span class="site-footer__pending">{messages.footer.contactPending}</span>
      </div>
      <div>
        <h2>{messages.footer.account}</h2>
        <a href={siteConfig.trialUrl}>{messages.navigation.startTrial}</a>
        {siteConfig.signInUrl ? <a href={siteConfig.signInUrl}>{messages.navigation.signIn}</a> : <span class="site-footer__pending">{messages.navigation.signInPendingTitle}</span>}
        <span class="site-footer__pending">{messages.footer.privacyPending}</span>
      </div>
    </div>
    <p class="site-footer__legal">© {new Date().getFullYear()} {messages.footer.legal}</p>
  </div>
</footer>
