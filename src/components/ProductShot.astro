---
interface Props {
  number: string;
  label: string;
  description: string;
  align?: 'start' | 'end';
}

const { number, label, description, align = 'start' } = Astro.props;
---

<figure class:list={['product-shot', `product-shot--${align}`]}>
  <div class="product-shot__frame" role="img" aria-label={`Placeholder for approved Trust Leader platform screen: ${label}. ${description}`}>
    <div class="product-shot__chrome" aria-hidden="true">
      <span></span><span></span><span></span>
      <b>Trust Leader</b>
    </div>
    <div class="product-shot__placeholder">
      <span>{number}</span>
      <strong>{label}</strong>
      <small>Approved platform screenshot to replace this panel</small>
    </div>
  </div>
  <figcaption>{description}</figcaption>
</figure>

