---
interface Props {
  number: string;
  label: string;
  description: string;
  image: string;
  alt: string;
  width: number;
  height: number;
}

const { number, label, description, image, alt, width, height } = Astro.props;
---

<figure class="product-shot">
  <div class="product-shot__frame">
    <img src={image} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
  </div>
  <figcaption><strong>{number} · {label}</strong><span>{description}</span></figcaption>
</figure>
