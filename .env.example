# Add only public, non-secret destinations here.
PUBLIC_SITE_URL=https://www.thetrustleader.com
PUBLIC_HUB_AUTH_URL=https://hub.thetrustleader.com/auth
PUBLIC_HUB_TRIAL_URL=https://hub.thetrustleader.com/auth?mode=signup
PUBLIC_HUB_PRACTITIONER_URL=https://hub.thetrustleader.com/auth?mode=signup&next=%2Fupgrade
PUBLIC_HUB_SIGN_IN_URL=
# Set only after the Hub verifies a locale handoff parameter, for example: lang
PUBLIC_HUB_LOCALE_PARAM=
# Optional. Analytics loads only after the visitor accepts analytics cookies.
PUBLIC_GA_MEASUREMENT_ID=
# Netlify preview and branch builds set this to true automatically.
PUBLIC_ROBOTS_NOINDEX=false
